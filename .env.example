# Copy to .env. With the default Claude SDK backend you need NO API key —
# it runs through your existing Claude Code login. A key is only needed for the
# 'anthropic' backend.

# --- LLM backend ---
# claude_sdk = Claude Agent SDK via your Claude Code login (no API key)
# anthropic  = raw Anthropic API (requires ANTHROPIC_API_KEY)
ADA_LLM_BACKEND=claude_sdk
ADA_SDK_MODEL=                 # optional model override for the SDK backend ("" = Claude Code default)

ANTHROPIC_API_KEY=            # only required if ADA_LLM_BACKEND=anthropic

# --- Models (used by the 'anthropic' backend) ---
ADA_ORCHESTRATOR_MODEL=claude-opus-4-8
ADA_AGENT_MODEL=claude-opus-4-8

# Effort per role: low | medium | high | xhigh | max
ADA_ORCHESTRATOR_EFFORT=high
ADA_AGENT_EFFORT=medium
ADA_REVIEWER_EFFORT=high

# --- LLM resilience (Tier 1) ---
ADA_REQUEST_TIMEOUT=120     # per-LLM-call HTTP timeout (seconds)
ADA_LLM_MAX_RETRIES=3       # bounded backoff retries on transient 429/5xx/timeout

# --- Session pool ---
ADA_MAX_CONCURRENT_SESSIONS=4
ADA_SESSION_IDLE_TTL=30
ADA_REAPER_INTERVAL=5
ADA_MAX_RETRIES=1           # review-retries per subtask

# --- Reliability (Tier 1) ---
# A subtask that produced real output but failed review becomes PASSED_WITH_CAVEATS so
# dependents still run, instead of one strict-review miss cascading BLOCKED through the DAG.
ADA_DEGRADE_ON_PARTIAL=true

# --- Verification (Tier 3): run the generated tests/lint and fold them into the verdict ---
ADA_VERIFY_RUN_TESTS=true
ADA_VERIFY_TIMEOUT=120
ADA_OBJECTIVE_REVIEW=true   # gate verdicts on real file contents + per-subtask tests
ADA_LINT_CHECK=true         # include a ruff/compile signal in the objective gate

# --- Planning (Tier 3) ---
ADA_ADAPTIVE_REPLAN=false   # let the orchestrator inject a repair subtask for a failed one
ADA_CLARIFY=false           # (reserved) ask clarifying questions before planning

# --- Real-repo binding (Tier 2): bind a run to an actual checked-out repository ---
ADA_REPO_URL=               # git URL to clone into the workspace (leave blank for greenfield)
ADA_REPO_PATH=              # OR a local repo path to copy into the sandbox (never mutated in place)
ADA_REPO_REF=               # branch/tag/sha to check out
ADA_GIT_FINALIZE=false      # commit the workspace on a new branch at the end of the run
ADA_GIT_BRANCH_PREFIX=ada/

# --- Sandbox / execution safety (Tier 2/5) ---
ADA_SANDBOX=subprocess      # "subprocess" (scrubbed env + rlimits) | "none"
ADA_SANDBOX_CPU_SECONDS=60
ADA_SANDBOX_MEM_MB=1024
ADA_ALLOW_RUN_COMMAND=true  # expose the run_command/install_packages agent tools
ADA_ALLOW_WEB=false         # allow built-in WebSearch/WebFetch in the SDK agent loop
ADA_ALLOWED_BUILTINS=Read,Write,Edit,Glob,Grep,LS   # SDK built-in tool allowlist (Bash denied by default)

# --- Defense in depth (Tier 5) ---
ADA_REDACT_SECRETS=true     # scrub secret-shaped strings from tool output/docs/memory
ADA_AUDIT_LOG=true          # append every tool dispatch to docs/<id>/audit.jsonl

# --- Observability (Tier 5) ---
ADA_TRACE=true              # write a per-run span log to docs/<id>/trace.jsonl
ADA_RECORD_DIR=             # if set, record provider calls as replay cassettes here
ADA_REPLAY_DIR=             # if set, serve provider calls from cassettes (offline, deterministic)

# --- Storage / embeddings ---
# fastembed = real local semantic embeddings (downloads a small ONNX model on first use)
# hash      = deterministic offline fallback (no download; weaker recall, used by tests)
ADA_EMBEDDINGS_BACKEND=fastembed
ADA_EMBED_MODEL=BAAI/bge-small-en-v1.5
ADA_DATA_DIR=.ada_data
ADA_DOCS_DIR=docs
# Sandbox where agents' built-in file/bash tools write generated code (kept out of source).
ADA_WORKSPACE_DIR=workspace
