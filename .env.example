# Copy to .env. With the default Claude SDK backend you need NO API key —
# it runs through your existing Claude Code login. A key is only needed for the
# 'anthropic' backend.

# --- LLM backend ---
# claude_sdk = Claude Agent SDK via your Claude Code login (no API key)
# anthropic  = raw Anthropic API (requires ANTHROPIC_API_KEY)
ADA_LLM_BACKEND=claude_sdk
ADA_SDK_MODEL=                 # optional model override for the SDK backend ("" = Claude Code default)

ANTHROPIC_API_KEY=            # only required if ADA_LLM_BACKEND=anthropic

# --- Models (used by the 'anthropic' backend) ---
ADA_ORCHESTRATOR_MODEL=claude-opus-4-8
ADA_AGENT_MODEL=claude-opus-4-8

# Effort per role: low | medium | high | xhigh | max
ADA_ORCHESTRATOR_EFFORT=high
ADA_AGENT_EFFORT=medium
ADA_REVIEWER_EFFORT=high

# --- Session pool ---
ADA_MAX_CONCURRENT_SESSIONS=4
ADA_SESSION_IDLE_TTL=30
ADA_REAPER_INTERVAL=5
ADA_MAX_RETRIES=1

# --- Verification: run the agents' generated tests after a task (objective pass/fail) ---
ADA_VERIFY_RUN_TESTS=true
ADA_VERIFY_TIMEOUT=120

# --- Storage / embeddings ---
# fastembed = real local semantic embeddings (downloads a small ONNX model on first use)
# hash      = deterministic offline fallback (no download; weaker recall, used by tests)
ADA_EMBEDDINGS_BACKEND=fastembed
ADA_EMBED_MODEL=BAAI/bge-small-en-v1.5
ADA_DATA_DIR=.ada_data
ADA_DOCS_DIR=docs
# Sandbox where agents' built-in file/bash tools write generated code (kept out of source).
ADA_WORKSPACE_DIR=workspace
